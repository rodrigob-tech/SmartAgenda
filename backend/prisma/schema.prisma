generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  scheduled
  confirmed
  pending
  canceled
  done
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
}

model Client {
  id           String        @id @default(uuid())
  name         String
  email        String
  phone        String
  appointments Appointment[]
}

model Space {
  id           String        @id @default(uuid())
  name         String
  description  String?
  appointments Appointment[]

}

model Appointment {
  id        String   @id @default(uuid())
  date      DateTime
  status    Status   @default(scheduled)
  reminderSent Boolean  @default(false)

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])

  spaceId   String
  space     Space   @relation(fields: [spaceId], references: [id])

  googleEventId      String?
  googleCalendarSync Boolean @default(false)
}

model BlockedTime {
  id    String   @id @default(uuid())
  start DateTime
  end   DateTime
}